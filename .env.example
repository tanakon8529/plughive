# ── Discord ──────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications (enable the
# "Message Content" privileged intent). DISCORD_CHANNEL_ID is the channel where
# scheduled briefs are posted (right-click channel → Copy Channel ID).
DISCORD_BOT_TOKEN=your.bot.token.here
DISCORD_CHANNEL_ID=0

# ── Claude CLI (the brain) ─────────────────────────────────────────────────
# No key needed if you've run `claude login` (uses your Claude subscription).
# Set this ONLY to override with a raw API key instead of your CLI login.
# ANTHROPIC_API_KEY=

# Optional: absolute path to the `claude` binary if it isn't on PATH.
# plughive auto-detects it, but you can pin it here.
# CLAUDE_BIN=/Users/you/.claude/local/claude

# ── Gmail + Calendar (optional) ────────────────────────────────────────────
# Powers mail/calendar in the brief via a local Google MCP server (config/mcp.json,
# runs on demand via npx — no Docker). Create your own OAuth "Desktop app" client
# in Google Cloud and paste its id/secret here, then authorize once.
# See README §Gmail/Calendar for the full walkthrough. Leave blank to run news-only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
